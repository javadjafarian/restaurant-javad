# ============================================
# Django Settings
# ============================================

# Secret Key - برای تولید: https://djecrety.ir/
SECRET_KEY=your-secret-key-here

# Debug Mode (True/False)
DEBUG=True

# Allowed Hosts (مثلاً: localhost,127.0.0.1,.example.com)
ALLOWED_HOSTS=localhost,127.0.0.1


# ============================================
# Database Settings
# ============================================

# Database Type: mysql, postgresql, sqlite3
DB_ENGINE=mysql

# Database Name
DB_NAME=your_database_name

# Database User
DB_USER=your_database_user

# Database Password
DB_PASSWORD=your_database_password

# Database Host
DB_HOST=localhost

# Database Port
DB_PORT=3306


# ============================================
# Email Settings (اختیاری)
# ============================================

# Email Backend: console, smtp
EMAIL_BACKEND=smtp

# SMTP Settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password


# ============================================
# Other Settings (اختیاری)
# ============================================

# Time Zone
TIME_ZONE=Asia/Tehran

# Language
LANGUAGE_CODE=fa

# Media URL
MEDIA_URL=/media/

# Static URL
STATIC_URL=/static/